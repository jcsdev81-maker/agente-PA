        @import url('https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=Inter:wght@300;400;500;600&display=swap');
        :root{
            --bg:#080e18;--bg2:#0f1c2b;--bg3:#152234;--bg4:#1b2a40;
            --blue:#3b9eff;--b0:rgba(59,158,255,.08);--b1:rgba(59,158,255,.18);
            --grn:#29e07f;--gd:rgba(41,224,127,.12);
            --amb:#f5a623;--ad:rgba(245,166,35,.12);
            --red:#ff4545;--rd:rgba(255,69,69,.12);
            --pur:#9b8afb;--pd:rgba(155,138,251,.12);
            --txt:#d8eeff;--t2:#6b93b8;--t3:#2f4b66;
            --sans:'Inter',sans-serif;--mono:'IBM Plex Mono',monospace;
            --r:8px;--rl:14px;--th:52px;--tbh:42px;
        }
        *{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
        html,body{height:100%;overflow:hidden;overscroll-behavior:none;font-family:var(--sans);background:var(--bg);color:var(--txt);font-size:14px}

        /* HEADER & TABS */
        #topbar{position:fixed;top:0;left:0;right:0;height:var(--th);z-index:300;display:flex;align-items:center;gap:12px;padding:0 16px;background:var(--bg2);border-bottom:1px solid var(--b0)}
        .lt h1{font-size:13px;font-weight:600}
        .lt p{font-size:9px;color:var(--t2);font-family:var(--mono)}
        #tabbar{position:fixed;top:var(--th);left:0;right:0;height:var(--tbh);z-index:300;display:flex;background:var(--bg2);border-bottom:1px solid var(--b0);overflow-x:auto}
        .tab{flex:1;min-width:80px;display:flex;align-items:center;justify-content:center;gap:5px;font-size:11px;font-family:var(--mono);color:var(--t3);cursor:pointer;transition:all .15s}
        .tab.on{color:var(--blue);border-bottom:2px solid var(--blue)}

        /* CONTENT SHELL */
        #shell{position:fixed;top:calc(var(--th) + var(--tbh));left:0;right:0;bottom:0;display:flex;overflow:hidden}
        .pane{display:none;width:100%;height:100%;overflow-y:auto;padding:14px;flex-direction:column;gap:12px}
        .pane.on{display:flex}

        /* CARDS & BUTTONS */
        .card{background:var(--bg2);border:1px solid var(--b0);border-radius:var(--rl);padding:14px}
        .ct{font-size:9px;font-family:var(--mono);color:var(--t2);text-transform:uppercase;margin-bottom:8px;display:flex;align-items:center;gap:6px}
        .ct::before{content:'';width:4px;height:4px;border-radius:50%;background:var(--blue)}
        .btn{display:inline-flex;align-items:center;justify-content:center;gap:6px;padding:10px 16px;border-radius:var(--r);font-size:12px;font-weight:500;cursor:pointer;border:none;transition:0.2s}
        .bp{background:var(--blue);color:#080e18}
        .bo{background:transparent;border:1px solid var(--b1);color:var(--t2)}
        
        /* INPUTS */
        .inp,.sel{width:100%;background:var(--bg3);border:1px solid var(--b0);border-radius:var(--r);padding:10px;color:var(--txt);font-family:var(--mono);outline:none}
        .fg2{display:grid;grid-template-columns:1fr 1fr;gap:10px}
        label.fl{display:block;font-size:9px;color:var(--t2);margin-bottom:4px;text-transform:uppercase}

        /* CHAT */
        #chat-log{flex:1;overflow-y:auto;display:flex;flex-direction:column;gap:10px;padding-bottom:10px}
        .cbbl{max-width:85%;padding:10px;border-radius:12px;font-size:12px;line-height:1.5}
